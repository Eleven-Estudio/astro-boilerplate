---
import Button from "@/components/globals/button.astro";
import ElevenEstudio from "@/components/icons/eleven-estudio.astro";
import SocialMedia from "@/components/social-media.astro";
import { BUSINESS_CONFIG } from "@/config/business";
import BaseLayout from "@/layouts/base-layout.astro";
---

<style>
  .eleven-brand::after,
  .eleven-brand::before {
    position: absolute;
    left: 50%;
    pointer-events: none;
    content: "";
    filter: blur(45px);
    transform: translateZ(0);
    animation: animate 5s alternate-reverse infinite;
  }

  .eleven-brand::before {
    width: 480px;
    height: 360px;
    margin-left: -400px;
    background: linear-gradient(
      to bottom right,
      rgba(81, 81, 81, 0),
      rgba(108, 108, 108, 0),
      rgba(107, 109, 113, 0.3)
    );
    border-radius: 50%;
  }
  .eleven-brand::after {
    width: 240px;
    height: 180px;
    background: radial-gradient(
      rgba(132, 132, 132, 0.4),
      rgba(211, 211, 211, 0)
    );
  }
</style>

<BaseLayout
  metadata={{
    title: "Astro Template Eleven",
    description: "Astro Template Eleven",
    ignoreTitleTemplate: true,
  }}
>
  <section
    class="relative eleven-brand flex flex-col gap-6 items-center justify-center h-screen bg-[#0b0b0b]"
  >
    <a
      class="z-10"
      href={BUSINESS_CONFIG.site}
      target="_blank"
      aria-label="Eleven Estudio"
      title="Link of website of Eleven Estudio"
      target="_blank"
    >
      <ElevenEstudio class="w-64 h-auto" />
    </a>
    <p class="text-gray-50 font-openSans">
      Get started by editing src/index.astro
    </p>
    <Button
      href="https://github.com/elevenestudio/astro-template-eleven"
      target="_blank">Get started</Button
    >
    <SocialMedia
      class="flex items-center gap-4 absolute bottom-10 left-1/2 transform -translate-x-1/2"
    />
  </section>
</BaseLayout>
