---
import type { SEOProps } from "astro-seo";
import { BUSINESS_CONFIG } from "@/config/business";

export interface Props extends SEOProps {}
const canonicalDefault = Astro.url.href;

const {
  title = BUSINESS_CONFIG.name,
  description = BUSINESS_CONFIG.description,
  canonical = canonicalDefault,
  openGraph = {},
  twitter = BUSINESS_CONFIG.social?.twitter,
  ignoreTitleTemplate = false,
  ...rest
} = Astro.props;

const ogImageUrl = openGraph?.image?.url || BUSINESS_CONFIG.openGraph;
const _absoluteImageUrl = ogImageUrl?.startsWith("http")
  ? ogImageUrl
  : ogImageUrl?.startsWith("/")
    ? `${Astro.site}${ogImageUrl}`
    : ogImageUrl
      ? `${Astro.site}/${ogImageUrl}`
      : BUSINESS_CONFIG.openGraph;
---

<SEO
  title={title}
  titleTemplate={ignoreTitleTemplate ? undefined : `%s - ${BUSINESS_CONFIG.name}`}
  description={description}
  canonical={canonical}
  openGraph={{
    basic: {
      title: title,
      type: "website",
      image: absoluteImageUrl,
    },
    optional: {
      description: description,
      siteName: BUSINESS_CONFIG.name,
      locale: "es_ES",
    },
  }}
  twitter={{
    card: "summary_large_image",
    site: BUSINESS_CONFIG.site,
    creator: twitter ?? "@yourhandle",
  }}
  {...rest}
/>

<meta name="twitter:image" content={absoluteImageUrl}>
<meta name="twitter:image:alt" content={title}>

<meta name="author" content={BUSINESS_CONFIG.name}>

<meta name="robots" content="index, follow">
<meta name="googlebot" content="index, follow">
