---
import { BUSINESS_CONFIG } from "@/config/business";

interface Props {
  id?: string;
}

const id = Astro.props.id ?? BUSINESS_CONFIG.googleTagManager?.id;
---

{id && (
  <noscript>
    <iframe
      src={`https://www.googletagmanager.com/ns.html?id=${id}`}
      height="0"
      width="0"
      style="display:none;visibility:hidden"
    />
  </noscript>
)}
